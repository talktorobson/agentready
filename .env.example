# Jira connector
JIRA_BASE_URL=https://jira.example.com
JIRA_TOKEN=your-personal-access-token

# GitHub connector
GITHUB_TOKEN=ghp_your-github-token

# OpenAPI connector (generic — works with any OpenAPI 3.x spec)
OPENAPI_SPEC_PATH=https://petstore3.swagger.io/api/v3/openapi.json
OPENAPI_BASE_URL=https://petstore3.swagger.io/api/v3
OPENAPI_AUTH_TOKEN=your-api-token
OPENAPI_AUTH_TYPE=bearer
