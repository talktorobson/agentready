{
  "name": "agentready",
  "version": "0.1.0",
  "description": "Define tools once, get both CLI and MCP server. The dual-interface framework for AI agent tooling.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentready": "dist/bin/agentready.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli/runner.js",
    "./mcp": "./dist/mcp/runner.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start:mcp": "node dist/bin/agentready.js mcp",
    "start:cli": "node dist/bin/agentready.js cli"
  },
  "keywords": ["ai", "agent", "mcp", "cli", "model-context-protocol", "tooling", "automation"],
  "author": "Robson",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
